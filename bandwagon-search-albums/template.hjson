{
	templateId: bandwagon-search-albums
	category: Bandwagon
	templateRole: search
	extends: ["bandwagon-search", "bandwagon-common"]
	model: Stream
	containedBy: ["top"]
	icon: album
	label: Bandwagon: Albums
	description: Search albums by name, hashtags, and license
	schema: {
		type:object
		properties: {
			label: {type:"string"}
			summary: {type:"string"}
			data: {
				type:object
				properties: {
					searchText: {type:"string"}
					content: {type:"string"}
				}
			}
		}    
	}

	actions: {
		view-albums: {
			roles: ["anonymous"]
			steps: [
				{do:"view-html"}
			]
		}

		feed: {
			roles: ["anonymous"]
			steps: [
				{do:"view-feed", search-types:["Album"]}
			]
		}
	}
}