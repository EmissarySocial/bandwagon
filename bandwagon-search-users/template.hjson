{
	templateId: bandwagon-search-users
	category: Bandwagon
	templateRole: search
	extends: ["bandwagon-search"]
	model: Stream
	containedBy: ["top"]
	icon: person
	label: Bandwagon: Artists
	description: Search artists by name, description, and hashtags
	schema: {
		type:object
		properties: {
			label: {type:"string"}
			summary: {type:"string"}
			data: {
				type:object
				properties: {
					searchText: {type:"string"}
					content: {type:"string"}
				}
			}
		}    
	}

	actions: {
		feed: {
			roles: ["anonymous"]
			steps: [
				{do:"view-feed", search-types:["Person"]}
			]
		}
	}
}